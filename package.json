{
  "name": "embeddings-cos-sim",
  "version": "0.3.2",
  "type": "module",
  "description": "Calculate cosine similarity using embeddings (FastText, Node2Vec, RDF2Vec, custom)",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andrefs/embeddings-cos-sim.git"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./lib/cosSim": {
      "types": "./dist/lib/cosSim.d.ts",
      "default": "./dist/lib/cosSim.js"
    },
    "./lib/utils": {
      "types": "./dist/lib/utils.d.ts",
      "default": "./dist/lib/utils.js"
    }
  },
   "bin": {
     "embeddings-cos-sim": "./dist/bin/embeddings-cos-sim.js",
     "embeddings-cos-sim-download": "./dist/bin/embeddings-cos-sim-download.js",
     "embeddings-cos-sim-level": "./dist/bin/embeddings-cos-sim-level.js",
     "embeddings-cos-sim-verify": "./dist/bin/embeddings-cos-sim-verify.js",
     "embeddings-cos-sim-embeddings": "./dist/bin/embeddings-cos-sim-embeddings.js"
   },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node build.mjs && ./node_modules/.bin/tsc --emitDeclarationOnly",
    "test": "vitest",
    "prepare": "npm run build"
  },
  "keywords": [
    "cosine",
    "similarity",
    "embeddings",
    "fasttext",
    "node2vec",
    "rdf2vec",
    "graph-embeddings"
  ],
  "author": "André Santos",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/andrefs/embeddings-cos-sim/issues"
  },
  "homepage": "https://github.com/andrefs/embeddings-cos-sim#readme",
  "dependencies": {
    "level": "^9.0.0",
    "undici-types": "^6.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "esbuild": "0.27.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
